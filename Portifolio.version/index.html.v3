<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Arthur Barbosa — Desenvolvedor Web Full-Stack. Sites, sistemas de gestão personalizados e automações para o seu negócio." />
  <meta name="author" content="Arthur Barbosa" />
  <title>Arthur Barbosa | Desenvolvedor Web Full-Stack</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root { --bg: #0a0e1a; --bg-soft: #111827; --accent: #10b981; --accent-2: #06b6d4; --text: #e5e7eb; --muted: #9ca3af; }
    * { -webkit-font-smoothing: antialiased; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; }
    .bg-grid {
      background-image: radial-gradient(circle at 20% 0%, rgba(16,185,129,0.08), transparent 40%), radial-gradient(circle at 80% 100%, rgba(6,182,212,0.08), transparent 40%), linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: auto, auto, 40px 40px, 40px 40px;
    }
    .gradient-text { background: linear-gradient(135deg, #10b981 0%, #06b6d4 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
    .btn-glow { position: relative; transition: all 0.3s ease; }
    .btn-glow::before { content: ''; position: absolute; inset: -2px; background: linear-gradient(135deg, #10b981, #06b6d4); border-radius: inherit; opacity: 0; filter: blur(12px); transition: opacity 0.3s ease; z-index: -1; }
    .btn-glow:hover::before { opacity: 0.7; }
    .btn-glow:hover { transform: translateY(-2px); }
    .card { background: rgba(17,24,39,0.6); border: 1px solid rgba(255,255,255,0.06); backdrop-filter: blur(10px); transition: all 0.4s cubic-bezier(0.4,0,0.2,1); }
    .card:hover { transform: translateY(-6px); border-color: rgba(16,185,129,0.4); box-shadow: 0 20px 40px -10px rgba(16,185,129,0.2); }
    .mockup { background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 14px; font-family: 'JetBrains Mono', monospace; font-size: 11px; }
    .mockup-bar { display: flex; align-items: center; gap: 6px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .mockup-dot { width: 8px; height: 8px; border-radius: 50%; }
    .reveal { opacity: 0; transform: translateY(15px); transition: all 0.5s cubic-bezier(0.4,0,0.2,1); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    ::-webkit-scrollbar { width: 10px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 5px; }
    ::-webkit-scrollbar-thumb:hover { background: #374151; }
    @keyframes pulse-dot { 0%,100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.6); } 50% { box-shadow: 0 0 0 8px rgba(16,185,129,0); } }
    .pulse-dot { animation: pulse-dot 2s infinite; }
    .mobile-menu { max-height: 0; overflow: hidden; transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1); }
    .mobile-menu.open { max-height: 450px; }
    @keyframes float-bounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
    .float-bounce { animation: float-bounce 3s ease-in-out infinite; }
    .tag { display: inline-block; padding: 4px 10px; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3); color: #10b981; border-radius: 999px; font-size: 12px; font-weight: 500; }
    .tag.cyan { background: rgba(6,182,212,0.1); border-color: rgba(6,182,212,0.3); color: #06b6d4; }
    .tag.amber { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.3); color: #f59e0b; }
    .faq-item { border-bottom: 1px solid rgba(255,255,255,0.05); }
    .faq-question { cursor: pointer; display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 0; transition: color 0.3s ease; }
    .faq-question:hover { color: #10b981; }
    .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1), padding 0.4s ease; padding: 0 0; color: #9ca3af; font-size: 0.95rem; line-height: 1.6; }
    .faq-item.active .faq-answer { max-height: 300px; padding: 0 0 1.25rem 0; }
    .faq-icon { transition: transform 0.3s ease; flex-shrink: 0; }
    .faq-item.active .faq-icon { transform: rotate(180deg); }

    /* MODAIS */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
    .modal-overlay.active { opacity: 1; pointer-events: all; }
    .modal-content { background: #111827; border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; max-width: 520px; width: 90%; max-height: 90vh; overflow-y: auto; transform: scale(0.9) translateY(20px); transition: transform 0.3s cubic-bezier(0.4,0,0.2,1); padding: 0; }
    .modal-overlay.active .modal-content { transform: scale(1) translateY(0); }
    .modal-header { padding: 24px 24px 0; display: flex; justify-content: space-between; align-items: center; }
    .modal-body { padding: 20px 24px 24px; }
    .modal-close { width: 36px; height: 36px; border-radius: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); color: #9ca3af; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
    .modal-close:hover { background: rgba(239,68,68,0.1); color: #ef4444; border-color: rgba(239,68,68,0.3); }

    /* Calendário */
    .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; margin-top: 12px; }
    .calendar-day-header { text-align: center; font-size: 11px; color: #6b7280; font-weight: 600; padding: 8px 0; }
    .calendar-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 10px; font-size: 13px; cursor: pointer; transition: all 0.2s; border: 1px solid transparent; color: #d1d5db; }
    .calendar-day:hover:not(.disabled):not(.selected) { background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.3); color: #10b981; }
    .calendar-day.selected { background: linear-gradient(135deg, #10b981, #06b6d4); color: #0a0e1a; font-weight: 700; box-shadow: 0 4px 15px rgba(16,185,129,0.3); }
    .calendar-day.disabled { color: #374151; cursor: not-allowed; }
    .calendar-day.today { border-color: rgba(16,185,129,0.5); color: #10b981; }
    .calendar-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .calendar-nav button { width: 32px; height: 32px; border-radius: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); color: #9ca3af; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
    .calendar-nav button:hover { background: rgba(16,185,129,0.1); color: #10b981; border-color: rgba(16,185,129,0.3); }
    .calendar-month-year { font-weight: 700; font-size: 15px; color: #e5e7eb; }

    /* Time slots */
    .time-slots { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 12px; }
    .time-slot { padding: 10px 8px; border-radius: 10px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); color: #9ca3af; font-size: 13px; text-align: center; cursor: pointer; transition: all 0.2s; }
    .time-slot:hover:not(.disabled):not(.selected) { background: rgba(6,182,212,0.1); border-color: rgba(6,182,212,0.3); color: #06b6d4; }
    .time-slot.selected { background: linear-gradient(135deg, #06b6d4, #0891b2); color: #0a0e1a; font-weight: 700; box-shadow: 0 4px 15px rgba(6,182,212,0.3); }
    .time-slot.disabled { opacity: 0.3; cursor: not-allowed; text-decoration: line-through; }

    /* Form */
    .form-input { width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; color: #e5e7eb; font-size: 14px; font-family: inherit; transition: all 0.2s; outline: none; }
    .form-input:focus { border-color: rgba(16,185,129,0.5); box-shadow: 0 0 0 3px rgba(16,185,129,0.1); }
    .form-input::placeholder { color: #4b5563; }
    .form-label { display: block; font-size: 12px; font-weight: 600; color: #9ca3af; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em; }

    /* Service selector */
    .service-option { padding: 12px 16px; border-radius: 12px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); cursor: pointer; transition: all 0.2s; display: flex; align-items: center; gap: 12px; }
    .service-option:hover:not(.selected) { background: rgba(16,185,129,0.05); border-color: rgba(16,185,129,0.2); }
    .service-option.selected { background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.4); }
    .service-option .check-circle { width: 20px; height: 20px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; transition: all 0.2s; flex-shrink: 0; }
    .service-option.selected .check-circle { background: #10b981; border-color: #10b981; }
    .service-option.selected .check-circle::after { content: '✓'; color: #0a0e1a; font-size: 12px; font-weight: 700; }

    /* Steps */
    .step-dots { display: flex; justify-content: center; gap: 8px; margin-bottom: 20px; }
    .step-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.1); transition: all 0.3s; }
    .step-dot.active { background: #10b981; box-shadow: 0 0 10px rgba(16,185,129,0.4); }
    .step-dot.completed { background: #06b6d4; }
    .progress-bar { height: 4px; background: rgba(255,255,255,0.05); border-radius: 2px; overflow: hidden; margin-bottom: 20px; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #10b981, #06b6d4); border-radius: 2px; transition: width 0.4s cubic-bezier(0.4,0,0.2,1); }

    @keyframes success-pop { 0% { transform: scale(0); opacity: 0; } 60% { transform: scale(1.1); } 100% { transform: scale(1); opacity: 1; } }
    .success-icon { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #10b981, #06b6d4); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; animation: success-pop 0.5s cubic-bezier(0.4,0,0.2,1) forwards; }
    .success-icon svg { width: 40px; height: 40px; color: #0a0e1a; }

    /* ERP */
    .erp-widget { background: rgba(0,0,0,0.3); border-radius: 10px; padding: 16px; border: 1px solid rgba(255,255,255,0.05); }
    .chart-bar { transition: height 0.6s cubic-bezier(0.4,0,0.2,1); }
    .tooltip { position: relative; }
    .tooltip::after { content: attr(data-tip); position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%) translateY(-6px); background: #1f2937; color: #e5e7eb; padding: 6px 12px; border-radius: 8px; font-size: 12px; white-space: nowrap; opacity: 0; pointer-events: none; transition: all 0.2s; border: 1px solid rgba(255,255,255,0.08); }
    .tooltip:hover::after { opacity: 1; transform: translateX(-50%) translateY(-4px); }

    /* Payment */
    .boleto-card { background: linear-gradient(135deg, rgba(245,158,11,0.1), rgba(245,158,11,0.02)); border: 1px solid rgba(245,158,11,0.2); border-radius: 12px; padding: 16px; transition: all 0.3s; cursor: pointer; }
    .boleto-card:hover { border-color: rgba(245,158,11,0.4); transform: translateX(4px); }
    .pix-card { background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(16,185,129,0.02)); border: 1px solid rgba(16,185,129,0.2); border-radius: 12px; padding: 16px; transition: all 0.3s; cursor: pointer; }
    .pix-card:hover { border-color: rgba(16,185,129,0.4); transform: translateX(4px); }

    /* Demo float */
    .demo-float { position: fixed; bottom: 24px; left: 24px; z-index: 50; background: linear-gradient(135deg, #10b981, #06b6d4); color: #0a0e1a; font-weight: 700; padding: 12px 20px; border-radius: 14px; box-shadow: 0 8px 30px rgba(16,185,129,0.3); cursor: pointer; transition: all 0.3s; display: flex; align-items: center; gap: 8px; font-size: 13px; }
    .demo-float:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(16,185,129,0.4); }
    @media (max-width: 768px) { .demo-float { display: none; } }

    /* Toast */
    @keyframes toast-in { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    @keyframes toast-out { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
    .toast { position: fixed; top: 90px; right: 24px; background: #111827; border: 1px solid rgba(16,185,129,0.3); border-radius: 12px; padding: 14px 20px; z-index: 200; display: flex; align-items: center; gap: 10px; box-shadow: 0 10px 40px rgba(0,0,0,0.4); animation: toast-in 0.3s ease forwards; }
    .toast.hiding { animation: toast-out 0.3s ease forwards; }
    .toast-icon { width: 28px; height: 28px; border-radius: 50%; background: rgba(16,185,129,0.15); display: flex; align-items: center; justify-content: center; }
    .toast-icon svg { width: 16px; height: 16px; color: #10b981; }

    @keyframes confetti-fall { 0% { transform: translateY(-10px) rotate(0deg); opacity: 1; } 100% { transform: translateY(100vh) rotate(720deg); opacity: 0; } }
    .confetti { position: fixed; width: 10px; height: 10px; z-index: 300; pointer-events: none; animation: confetti-fall 2s ease-out forwards; }
  </style>
</head>
<body class="bg-grid">

  <!-- Botão flutuante de demonstração -->
  <div class="demo-float" onclick="openModal('modal-demo')">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    Ver Demonstrações
  </div>

  <!-- ===================== MODAIS ===================== -->

  <!-- Modal de Agendamento -->
  <div id="modal-agendamento" class="modal-overlay" onclick="closeModal(event, 'modal-agendamento')">
    <div class="modal-content" onclick="event.stopPropagation()">
      <div class="modal-header">
        <div>
          <h3 class="text-xl font-bold">Agendar Demonstração</h3>
          <p class="text-sm text-gray-500 mt-1">Escolha data, horário e serviço</p>
        </div>
        <button class="modal-close" onclick="closeModalDirect('modal-agendamento')">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="progress-bar"><div class="progress-fill" id="agendamento-progress" style="width: 25%"></div></div>
        <div class="step-dots">
          <div class="step-dot active" id="dot-1"></div>
          <div class="step-dot" id="dot-2"></div>
          <div class="step-dot" id="dot-3"></div>
          <div class="step-dot" id="dot-4"></div>
        </div>

        <!-- Etapa 1: Serviço -->
        <div id="step-1">
          <p class="form-label">Qual serviço você precisa?</p>
          <div class="space-y-2" id="service-list">
            <div class="service-option selected" data-service="Site Institucional" onclick="selectService(this)">
              <div class="check-circle"></div>
              <div><div class="font-semibold text-sm">Site Institucional</div><div class="text-xs text-gray-500">Presença online profissional</div></div>
            </div>
            <div class="service-option" data-service="Landing Page" onclick="selectService(this)">
              <div class="check-circle"></div>
              <div><div class="font-semibold text-sm">Landing Page</div><div class="text-xs text-gray-500">Alta conversão para campanhas</div></div>
            </div>
            <div class="service-option" data-service="Sistema Customizado" onclick="selectService(this)">
              <div class="check-circle"></div>
              <div><div class="font-semibold text-sm">Sistema Customizado</div><div class="text-xs text-gray-500">ERP, gestão ou automação</div></div>
            </div>
            <div class="service-option" data-service="E-commerce" onclick="selectService(this)">
              <div class="check-circle"></div>
              <div><div class="font-semibold text-sm">E-commerce</div><div class="text-xs text-gray-500">Loja virtual completa</div></div>
            </div>
          </div>
          <button class="w-full mt-6 bg-emerald-500 hover:bg-emerald-400 text-[#0a0e1a] font-bold py-3 rounded-xl transition btn-glow" onclick="nextStep(2)">Continuar →</button>
        </div>

        <!-- Etapa 2: Data -->
        <div id="step-2" style="display:none">
          <p class="form-label">Escolha uma data</p>
          <div class="calendar-nav">
            <button onclick="changeMonth(-1)">‹</button>
            <span class="calendar-month-year" id="calendar-month-year"></span>
            <button onclick="changeMonth(1)">›</button>
          </div>
          <div class="calendar-grid" id="calendar-header">
            <div class="calendar-day-header">Dom</div><div class="calendar-day-header">Seg</div><div class="calendar-day-header">Ter</div><div class="calendar-day-header">Qua</div><div class="calendar-day-header">Qui</div><div class="calendar-day-header">Sex</div><div class="calendar-day-header">Sáb</div>
          </div>
          <div class="calendar-grid" id="calendar-days"></div>
          <div class="flex gap-3 mt-6">
            <button class="flex-1 bg-white/5 hover:bg-white/10 text-white font-semibold py-3 rounded-xl transition border border-white/10" onclick="prevStep(1)">← Voltar</button>
            <button class="flex-1 bg-emerald-500 hover:bg-emerald-400 text-[#0a0e1a] font-bold py-3 rounded-xl transition btn-glow" onclick="nextStep(3)">Continuar →</button>
          </div>
        </div>

        <!-- Etapa 3: Horário -->
        <div id="step-3" style="display:none">
          <p class="form-label">Horários disponíveis para <span id="selected-date-display" class="text-emerald-400"></span></p>
          <div class="time-slots" id="time-slots"></div>
          <div class="flex gap-3 mt-6">
            <button class="flex-1 bg-white/5 hover:bg-white/10 text-white font-semibold py-3 rounded-xl transition border border-white/10" onclick="prevStep(2)">← Voltar</button>
            <button class="flex-1 bg-emerald-500 hover:bg-emerald-400 text-[#0a0e1a] font-bold py-3 rounded-xl transition btn-glow" onclick="nextStep(4)">Continuar →</button>
          </div>
        </div>

        <!-- Etapa 4: Dados -->
        <div id="step-4" style="display:none">
          <p class="form-label">Seus dados</p>
          <div class="space-y-4">
            <div><label class="form-label">Nome completo</label><input type="text" class="form-input" placeholder="Seu nome" id="input-nome"></div>
            <div><label class="form-label">WhatsApp</label><input type="tel" class="form-input" placeholder="(34) 99999-9999" id="input-whatsapp"></div>
            <div><label class="form-label">Email</label><input type="email" class="form-input" placeholder="seu@email.com" id="input-email"></div>
            <div><label class="form-label">Observações (opcional)</label><textarea class="form-input" rows="3" placeholder="Conte um pouco sobre seu projeto..." id="input-obs"></textarea></div>
          </div>
          <div class="flex gap-3 mt-6">
            <button class="flex-1 bg-white/5 hover:bg-white/10 text-white font-semibold py-3 rounded-xl transition border border-white/10" onclick="prevStep(3)">← Voltar</button>
            <button class="flex-1 bg-emerald-500 hover:bg-emerald-400 text-[#0a0e1a] font-bold py-3 rounded-xl transition btn-glow" onclick="confirmarAgendamento()">Confirmar Agendamento ✓</button>
          </div>
        </div>

        <!-- Sucesso -->
        <div id="step-success" style="display:none; text-align:center; padding: 20px 0;">
          <div class="success-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg></div>
          <h4 class="text-2xl font-bold mb-2">Agendamento Confirmado!</h4>
          <p class="text-gray-400 text-sm mb-1">Sua mensagem foi preparada! Clique no botão abaixo para enviar pelo WhatsApp.</p>
          <div class="mt-4 p-4 bg-white/5 rounded-xl border border-white/5">
            <div class="text-sm text-gray-400">Resumo do agendamento</div>
            <div class="font-semibold text-emerald-400 mt-1" id="resumo-servico"></div>
            <div class="text-sm text-gray-300 mt-1" id="resumo-datahora"></div>
          </div>
          <div class="flex flex-col gap-3 mt-6">
            <a id="wa-redirect-link" href="https://wa.me/5534999545440" target="_blank" class="w-full bg-emerald-500 hover:bg-emerald-400 text-[#0a0e1a] font-bold py-3 rounded-xl transition btn-glow flex items-center justify-center gap-2">
