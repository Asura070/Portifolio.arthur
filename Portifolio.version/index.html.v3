  <!-- ===================== FAQ ===================== -->
  <section id="faq" class="py-20 md:py-28 border-t border-white/5">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16 reveal">
        <span class="tag mb-4 inline-block">Dúvidas Frequentes</span>
        <h2 class="text-4xl md:text-5xl font-bold mb-4">Perguntas <span class="gradient-text">comuns</span></h2>
        <p class="text-gray-400">Tire suas dúvidas sobre processo, valores e entregas. Se não encontrar o que procura, me chama no WhatsApp.</p>
      </div>
      <div class="space-y-2 reveal">
        <div class="faq-item card rounded-xl px-6">
          <div class="faq-question"><span class="font-semibold text-white">Quanto tempo leva para desenvolver um sistema?</span><svg class="faq-icon w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></div>
          <div class="faq-answer">Depende da complexidade. Um site institucional leva de 5 a 10 dias úteis. Já sistemas personalizados com dashboard e automações podem levar de 3 a 8 semanas. Sempre apresento um cronograma detalhado na proposta.</div>
        </div>
        <div class="faq-item card rounded-xl px-6">
          <div class="faq-question"><span class="font-semibold text-white">Como funciona o pagamento?</span><svg class="faq-icon w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></div>
          <div class="faq-answer">Trabalho com parcelamento em 2 ou 3 vezes: 50% na aprovação da proposta, 25% na entrega da versão beta e 25% no deploy final. Para projetos maiores, podemos negociar um fluxo personalizado.</div>
        </div>
        <div class="faq-item card rounded-xl px-6">
          <div class="faq-question"><span class="font-semibold text-white">Você faz manutenção após a entrega?</span><svg class="faq-icon w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></div>
          <div class="faq-answer">Sim! Ofereço planos mensais de suporte que incluem monitoramento, backups, pequenas atualizações e segurança. Você foca no negócio e eu cuido da tecnologia rodando.</div>
        </div>
        <div class="faq-item card rounded-xl px-6">
          <div class="faq-question"><span class="font-semibold text-white">O sistema vai funcionar no celular?</span><svg class="faq-icon w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></div>
          <div class="faq-answer">Absolutamente. Todo projeto é desenvolvido com abordagem Mobile First, ou seja, otimizado para celular desde o primeiro dia. Tablets e desktops também são totalmente responsivos.</div>
        </div>
        <div class="faq-item card rounded-xl px-6">
          <div class="faq-question"><span class="font-semibold text-white">Meu negócio é pequeno, ainda vale a pena?</span><svg class="faq-icon w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></div>
          <div class="faq-answer">Com certeza. Muitos dos meus clientes começaram com uma landing page ou um sistema simples de agendamento. A ideia é criar uma solução que cresça junto com seu negócio, sem desperdiçar investimento.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CONTATO ===================== -->
  <section id="contato" class="py-20 md:py-28 border-t border-white/5">
    <div class="max-w-4xl mx-auto px-6">
      <div class="card rounded-3xl p-8 md:p-16 text-center relative overflow-hidden reveal">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-gradient-to-br from-emerald-500/20 to-cyan-500/20 blur-3xl -z-0"></div>
        <div class="relative">
          <span class="tag mb-6 inline-block">Bora começar?</span>
          <h2 class="text-4xl md:text-6xl font-black mb-6">Tem um projeto<br><span class="gradient-text">em mente?</span></h2>
          <p class="text-lg text-gray-400 max-w-xl mx-auto mb-10">Me chama no WhatsApp. Vamos desenhar juntos o sistema ideal para otimizar o faturamento e a escala da sua operação.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://wa.me/5534999545440?text=Oi%20Arthur!%20Vim%20pelo%20seu%20portf%C3%B3lio%20e%20quero%20conversar%20sobre%20um%20projeto" target="_blank" class="inline-flex items-center justify-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-[#0a0e1a] font-semibold px-8 py-4 rounded-xl transition btn-glow text-lg">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              Chamar no WhatsApp
            </a>
            <a href="mailto:arthurbarbosabrito8@gmail.com" class="inline-flex items-center justify-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold px-8 py-4 rounded-xl transition">Enviar e-mail</a>
          </div>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-500">
            <div class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>Atendimento Digital & Presencial</div>
            <div class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>arthurbarbosabrito8@gmail.com</div>
            <div class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>(34) 99954-5440</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="border-t border-white/5 py-8">
    <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <div>© 2026 Arthur Barbosa. Desenvolvendo soluções com alta performance.</div>
      <div class="flex gap-4">
        <a href="https://wa.me/5534999545440" target="_blank" class="hover:text-emerald-400 transition">WhatsApp</a>
        <a href="mailto:arthurbarbosabrito8@gmail.com" class="hover:text-emerald-400 transition">E-mail</a>
      </div>
    </div>
  </footer>

  <!-- WhatsApp flutuante mobile -->
  <a href="https://wa.me/5534999545440" target="_blank" class="md:hidden fixed bottom-6 right-6 w-14 h-14 bg-emerald-500 rounded-full flex items-center justify-center shadow-lg float-bounce z-40">
    <svg class="w-7 h-7 text-[#0a0e1a]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
  </a>

  <script>
    // ===================== MENU MOBILE =====================
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn.addEventListener('click', () => { mobileMenu.classList.toggle('open'); });
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu.classList.remove('open'));
    });

    // ===================== SCROLL REVEAL =====================
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ===================== FAQ ACCORDION =====================
    document.querySelectorAll('.faq-question').forEach(question => {
      question.addEventListener('click', () => {
        const item = question.parentElement;
        const isActive = item.classList.contains('active');
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
        if (!isActive) item.classList.add('active');
      });
    });

    // ===================== MODAL SYSTEM =====================
    function openModal(id) {
      document.getElementById(id).classList.add('active');
      document.body.style.overflow = 'hidden';
      if (id === 'modal-agendamento') { initCalendar(); }
    }
    function closeModal(event, id) {
      if (event.target.id === id) { closeModalDirect(id); }
    }
    function closeModalDirect(id) {
      document.getElementById(id).classList.remove('active');
      document.body.style.overflow = '';
    }
    function openDemoModal() { openModal('modal-demo'); }

    // ===================== AGENDAMENTO - CALENDÁRIO =====================
    let currentMonth = new Date().getMonth();
    let currentYear = new Date().getFullYear();
    let selectedDate = null;
    let selectedService = 'Site Institucional';
    let selectedTime = null;
    const monthNames = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

    function initCalendar() {
      renderCalendar();
    }
    function renderCalendar() {
      document.getElementById('calendar-month-year').textContent = monthNames[currentMonth] + ' ' + currentYear;
      const firstDay = new Date(currentYear, currentMonth, 1).getDay();
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
      const today = new Date();
      let html = '';
      for (let i = 0; i < firstDay; i++) html += '<div class="calendar-day disabled"></div>';
      for (let d = 1; d <= daysInMonth; d++) {
        const date = new Date(currentYear, currentMonth, d);
        const isToday = date.toDateString() === today.toDateString();
        const isPast = date < new Date(today.setHours(0,0,0,0));
        const isSelected = selectedDate && date.toDateString() === selectedDate.toDateString();
        let classes = 'calendar-day';
        if (isPast) classes += ' disabled';
        if (isToday) classes += ' today';
        if (isSelected) classes += ' selected';
        if (!isPast) {
          html += '<div class="' + classes + '" onclick="selectDate(' + currentYear + ',' + currentMonth + ',' + d + ')">' + d + '</div>';
        } else {
          html += '<div class="' + classes + '">' + d + '</div>';
        }
      }
      document.getElementById('calendar-days').innerHTML = html;
    }
    function changeMonth(delta) {
      currentMonth += delta;
      if (currentMonth > 11) { currentMonth = 0; currentYear++; }
      if (currentMonth < 0) { currentMonth = 11; currentYear--; }
      renderCalendar();
    }
    function selectDate(y, m, d) {
      selectedDate = new Date(y, m, d);
      renderCalendar();
      generateTimeSlots();
    }
    function generateTimeSlots() {
      const slots = ['09:00','09:30','10:00','10:30','11:00','14:00','14:30','15:00','15:30','16:00','16:30','17:00'];
      const container = document.getElementById('time-slots');
      let html = '';
      slots.forEach((slot, i) => {
        const disabled = Math.random() > 0.7;
        let classes = 'time-slot';
        if (disabled) classes += ' disabled';
        if (selectedTime === slot) classes += ' selected';
        html += '<div class="' + classes + '" ' + (disabled ? '' : 'onclick="selectTime(\'' + slot + '\')"') + '>' + slot + '</div>';
      });
      container.innerHTML = html;
    }
    function selectTime(time) {
      selectedTime = time;
      generateTimeSlots();
    }
    function selectService(el) {
      document.querySelectorAll('.service-option').forEach(o => o.classList.remove('selected'));
      el.classList.add('selected');
      selectedService = el.dataset.service;
    }
    function nextStep(step) {
      if (step === 3 && !selectedDate) { showToast('Selecione uma data primeiro', 'warning'); return; }
      if (step === 4 && !selectedTime) { showToast('Selecione um horário', 'warning'); return; }
      for (let i = 1; i <= 4; i++) document.getElementById('step-' + i).style.display = 'none';
      document.getElementById('step-' + step).style.display = 'block';
      document.getElementById('agendamento-progress').style.width = (step * 25) + '%';
      for (let i = 1; i <= 4; i++) {
        const dot = document.getElementById('dot-' + i);
        dot.classList.remove('active', 'completed');
        if (i < step) dot.classList.add('completed');
        if (i === step) dot.classList.add('active');
      }
      if (step === 3 && selectedDate) {
        document.getElementById('selected-date-display').textContent = selectedDate.toLocaleDateString('pt-BR', {day:'numeric', month:'long'});
      }
    }
    function prevStep(step) {
      for (let i = 1; i <= 4; i++) document.getElementById('step-' + i).style.display = 'none';
      document.getElementById('step-' + step).style.display = 'block';
      document.getElementById('agendamento-progress').style.width = (step * 25) + '%';
      for (let i = 1; i <= 4; i++) {
        const dot = document.getElementById('dot-' + i);
        dot.classList.remove('active', 'completed');
        if (i < step) dot.classList.add('completed');
        if (i === step) dot.classList.add('active');
      }
    }
    function confirmarAgendamento() {
      const nome = document.getElementById('input-nome').value.trim();
      const whatsapp = document.getElementById('input-whatsapp').value.trim();
      const email = document.getElementById('input-email').value.trim();
      const obs = document.getElementById('input-obs').value.trim();

      if (!nome || !whatsapp) { showToast('Preencha nome e WhatsApp', 'warning'); return; }
      if (!selectedDate || !selectedTime) { showToast('Selecione data e horário', 'warning'); return; }

      // Formata a mensagem para o WhatsApp
      const dataFormatada = selectedDate.toLocaleDateString('pt-BR', {day:'2-digit', month:'long', year:'numeric'});
      let mensagem = 'Oi Arthur! Vim pelo seu portfólio e quero agendar uma reunião.%0A%0A';
      mensagem += '*Serviço:* ' + selectedService + '%0A';
      mensagem += '*Data:* ' + dataFormatada + '%0A';
      mensagem += '*Horário:* ' + selectedTime + '%0A';
      mensagem += '*Nome:* ' + nome + '%0A';
      mensagem += '*WhatsApp:* ' + whatsapp;
      if (email) mensagem += '%0A*Email:* ' + email;
      if (obs) mensagem += '%0A%0A*Observações:* ' + obs;
      mensagem += '%0A%0APode confirmar esse horário?';

      // Abre o WhatsApp com a mensagem
      const waUrl = 'https://wa.me/5534999545440?text=' + mensagem;
      window.open(waUrl, '_blank');

      // Mostra tela de sucesso
      document.getElementById('step-4').style.display = 'none';
      document.getElementById('step-success').style.display = 'block';
      document.getElementById('resumo-servico').textContent = selectedService;
      document.getElementById('resumo-datahora').textContent = dataFormatada + ' às ' + selectedTime;
      createConfetti();
      showToast('Redirecionando para o WhatsApp...', 'success');
    }
    function resetAgendamento() {
      selectedDate = null; selectedTime = null; currentMonth = new Date().getMonth(); currentYear = new Date().getFullYear();
      document.getElementById('step-success').style.display = 'none';
      document.getElementById('step-1').style.display = 'block';
      document.getElementById('agendamento-progress').style.width = '25%';
      for (let i = 1; i <= 4; i++) {
        const dot = document.getElementById('dot-' + i);
        dot.classList.remove('active', 'completed');
        if (i === 1) dot.classList.add('active');
      }
      document.getElementById('input-nome').value = '';
      document.getElementById('input-whatsapp').value = '';
      document.getElementById('input-email').value = '';
      document.getElementById('input-obs').value = '';
    }

    // ===================== ERP DASHBOARD =====================
    function updateERPStat(el) {
      const valueEl = el.querySelector('.erp-value');
      const target = parseFloat(valueEl.dataset.target);
      const variation = (Math.random() * 0.4 - 0.2);
      const newVal = Math.round(target * (1 + variation));
      if (valueEl.textContent.includes('R$')) {
        valueEl.textContent = 'R$ ' + (newVal / 1000).toFixed(1) + 'k';
      } else if (valueEl.textContent.includes('%')) {
        valueEl.textContent = (newVal / 100).toFixed(1) + '%';
      } else {
        valueEl.textContent = newVal.toLocaleString('pt-BR');
      }
      el.style.transform = 'scale(1.05)';
      setTimeout(() => el.style.transform = 'scale(1)', 200);
      showToast('Dados atualizados em tempo real!', 'success');
    }
    function randomizeChart() {
      const bars = document.querySelectorAll('#chart-bars .chart-bar');
      const days = ['Seg','Ter','Qua','Qui','Sex','Sáb','Dom'];
      bars.forEach((bar, i) => {
        const h = Math.floor(Math.random() * 60 + 30);
        bar.style.height = h + '%';
        const val = (h * 0.12).toFixed(1);
        bar.dataset.tip = days[i] + ': R$ ' + val + 'k';
      });
      showToast('Gráfico atualizado!', 'success');
    }

    // ===================== COBRANÇA =====================
    function selectPayment(method) {
      document.getElementById('pay-pix').classList.remove('selected');
      document.getElementById('pay-boleto').classList.remove('selected');
      document.getElementById('pay-' + method).classList.add('selected');
      if (method === 'pix') {
        document.getElementById('pix-area').style.display = 'block';
        document.getElementById('boleto-area').style.display = 'none';
      } else {
        document.getElementById('pix-area').style.display = 'none';
        document.getElementById('boleto-area').style.display = 'block';
      }
    }
    function simulatePayment() {
      document.getElementById('pix-area').style.display = 'none';
      document.getElementById('boleto-area').style.display = 'none';
      document.getElementById('payment-success').style.display = 'block';
      createConfetti();
      showToast('Pagamento processado com sucesso!', 'success');
    }
    function copyPix() {
      navigator.clipboard.writeText('00020126580014BR.GOV.BCB.PIX0136+55349995454405204000053039865802BR5913ARTHUR BARBOSA6009Uberlandia62070503***6304E2CA');
      showToast('Código Pix copiado!', 'success');
    }
    function copyBoleto() {
      navigator.clipboard.writeText('34191.79001 01043.510047 91020.150008 9 89250000025000');
      showToast('Código de barras copiado!', 'success');
    }

    // ===================== E-COMMERCE =====================
    let cart = [];
    function addToCart(name, price, el) {
      cart.push({ name, price });
      updateCart();
      el.style.transform = 'scale(0.95)';
      setTimeout(() => el.style.transform = '', 150);
      showToast(name + ' adicionado ao carrinho!', 'success');
    }
    function updateCart() {
      const count = cart.length;
      const total = cart.reduce((sum, item) => sum + item.price, 0);
      document.getElementById('cart-count').textContent = count;
      document.getElementById('cart-total').textContent = 'R$ ' + total.toFixed(2).replace('.', ',');
    }
    function checkout() {
      if (cart.length === 0) { showToast('Adicione itens ao carrinho primeiro', 'warning'); return; }
      document.getElementById('product-grid').style.display = 'none';
      document.getElementById('checkout-success').style.display = 'block';
      const itemsContainer = document.getElementById('checkout-items');
      let html = '';
      cart.forEach(item => {
        html += '<div class="flex justify-between text-sm py-1"><span class="text-gray-300">' + item.name + '</span><span class="text-emerald-400">R$ ' + item.price.toFixed(2).replace('.', ',') + '</span></div>';
      });
      itemsContainer.innerHTML = html;
      const total = cart.reduce((sum, item) => sum + item.price, 0);
      document.getElementById('checkout-total').textContent = 'R$ ' + total.toFixed(2).replace('.', ',');
      createConfetti();
      showToast('Compra finalizada!', 'success');
    }

    // ===================== TOAST =====================
    function showToast(message, type) {
      const existing = document.querySelector('.toast');
      if (existing) existing.remove();
      const toast = document.createElement('div');
      toast.className = 'toast';
      const iconColor = type === 'success' ? '#10b981' : '#f59e0b';
      const iconSvg = type === 'success'
        ? '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>'
        : '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>';
      toast.innerHTML = '<div class="toast-icon" style="background:' + iconColor + '15;color:' + iconColor + '">' + iconSvg + '</div><div><div class="text-sm font-semibold">' + message + '</div></div>';
      document.body.appendChild(toast);
      setTimeout(() => {
        toast.classList.add('hiding');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    // ===================== CONFETTI =====================
    function createConfetti() {
      const colors = ['#10b981', '#06b6d4', '#f59e0b', '#8b5cf6', '#ec4899'];
      for (let i = 0; i < 30; i++) {
        const conf = document.createElement('div');
        conf.className = 'confetti';
        conf.style.left = Math.random() * 100 + 'vw';
        conf.style.background = colors[Math.floor(Math.random() * colors.length)];
        conf.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
        conf.style.width = (Math.random() * 8 + 4) + 'px';
        conf.style.height = (Math.random() * 8 + 4) + 'px';
        conf.style.animationDelay = (Math.random() * 0.5) + 's';
        conf.style.animationDuration = (Math.random() * 1 + 1.5) + 's';
        document.body.appendChild(conf);
        setTimeout(() => conf.remove(), 2500);
      }
    }
  </script>
</body>
</html>
